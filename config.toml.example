# uniskill configuration
# Place this at ~/.config/uniskill/config.toml or pass --config

# Whole-bundle source: point at a bundle directory in a git repo (containing
# meta.toml + skills/) and pull every skill it declares as a unit.
[bundles.generic]
harnesses = ["pi", "claude-code"]
repo = "gh:lutyjj/agent-skills"
ref = "main"
path = "bundles/generic"

# Explicit skills layer on top of the bundle source: add skills it does not
# vendor, or override one by name. Here caveman comes from a raw SKILL.md URL.
[bundles.generic.skills.caveman]
url = "https://raw.githubusercontent.com/JuliusBrussee/caveman/refs/heads/main/skills/caveman/SKILL.md"

# Live workflow: point at a LOCAL clone and edit from any harness. A local
# `source` is symlinked straight to its working tree (link = true, the default),
# so edits through a harness land in the repo and `git pull` is live — re-sync
# only when you add or remove a skill. Relative paths resolve against this file.
[bundles.local-live]
harnesses = ["pi", "claude-code"]
source = "../bundles/generic"
# link = false   # opt out: snapshot the local source by copy instead

# A bundle can also be composed purely from explicit skills, each with its own
# source: a local directory, a git repo path, or a URL.
[bundles.handpicked]
harnesses = ["pi"]

[bundles.handpicked.skills.code-design]
repo = "gh:lutyjj/agent-skills"
ref = "main"
path = "bundles/generic/skills/code-design"

[bundles.handpicked.skills.local-example]
source = "$HOME/.dotfiles/skills/local-example"

[harnesses.my-custom-harness]
label = "My Custom Harness"
pattern = "/custom/path/skills/{name}"
